# AgentForge Environment Variables

# LLM Providers (Gemini 2.5 Flash is the default)
GEMINI_API_KEY=your_gemini_api_key_here

# Search Engines (Tavily is used by the Research Agent)
TAVILY_API_KEY=your_tavily_api_key_here

# Database Settings
DATABASE_URL=sqlite:///./agentforge.db

# API Settings
HOST=0.0.0.0
PORT=8000

# MCP (Model Context Protocol) Server Configurations (JSON String)
# Example of configured external servers. Set to empty JSON array [] to run with built-in tools.
MCP_SERVERS_JSON=[]
